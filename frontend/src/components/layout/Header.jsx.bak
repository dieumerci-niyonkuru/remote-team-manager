import { useState, useRef, useEffect } from 'react'
import { Link, useNavigate, useLocation } from 'react-router-dom'
import { useStore } from '../../store'
import { useT } from '../../i18n'
import { auth } from '../../services/api'
import toast from 'react-hot-toast'
import AIAssistantModal from '../common/AIAssistantModal'
import UserDropdown from '../common/UserDropdown'

export default function Header() {
  const { isAuth, user, theme, setTheme, lang, setLang } = useStore()
  const t = useT(lang)
  const navigate = useNavigate()
  const { pathname } = useLocation()
  const [search, setSearch] = useState('')
  const [openDropdown, setOpenDropdown] = useState(null)
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false)
  const [aiModalOpen, setAiModalOpen] = useState(false)
  const dropdownRef = useRef(null)

  useEffect(() => {
    const handleClickOutside = (e) => {
      if (mobileMenuOpen && !e.target.closest('.mobile-menu-container')) {
        setMobileMenuOpen(false)
      }
      if (dropdownRef.current && !dropdownRef.current.contains(e.target)) {
        setOpenDropdown(null)
      }
    }
    document.addEventListener('mousedown', handleClickOutside)
    return () => document.removeEventListener('mousedown', handleClickOutside)
  }, [mobileMenuOpen])

  const handleSearch = (e) => {
    e.preventDefault()
    if (!search.trim()) return
    if (pathname === '/dashboard' || pathname === '/workspaces')
      navigate(`/dashboard?search=${encodeURIComponent(search)}`)
    else if (pathname.startsWith('/workspaces/'))
      navigate(`${pathname}?search=${encodeURIComponent(search)}`)
    setMobileMenuOpen(false)
  }

  const solutionItems = [
    { label: t.solTeamMgmt, path: '/solutions/team-management' },
    { label: t.solTaskTracking, path: '/solutions/task-tracking' },
    { label: t.solTimeLogging, path: '/solutions/time-logging' },
    { label: t.solActivityFeed, path: '/solutions/activity-feed' },
  ]
  const resourceItems = [
    { label: t.resApiDocs, href: 'https://remote-team-manager-production.up.railway.app/api/docs/', external: true },
    { label: t.resGitHub, href: 'https://github.com/dieumerci-niyonkuru/remote-team-manager', external: true },
    { label: t.resHealth, href: 'https://remote-team-manager-production.up.railway.app/api/health/', external: true },
    { label: t.resSupport, href: '/support' },
  ]

  const isActive = (to) => to === '/' ? pathname === '/' : pathname.startsWith(to)

  const handleDropdownClick = (href, external) => {
    setOpenDropdown(null)
    setMobileMenuOpen(false)
    if (external) window.open(href, '_blank')
    else navigate(href)
  }

  const languages = [
    { code: 'en', name: 'English', flag: '🇬🇧' },
    { code: 'fr', name: 'Français', flag: '🇫🇷' },
    { code: 'rw', name: 'Kinyarwanda', flag: '🇷🇼' },
  ]

  const publicLinks = [
    { to: '/', label: t.home },
    { type: 'dropdown', label: t.solutions, items: solutionItems },
    { type: 'dropdown', label: t.resources, items: resourceItems },
    { to: '/about', label: t.about },
  ]
  const privateLinks = [
    { to: '/dashboard', label: t.dashboard },
    { to: '/workspaces', label: t.workspaces },
    { to: '/team', label: t.team },
    { to: '/activity', label: t.activity },
  ]
  const currentLinks = isAuth ? privateLinks : publicLinks

  const renderNavItem = (item) => {
    if (item.to) {
      return (
        <Link
          key={item.to}
          to={item.to}
          className={`nav-link ${isActive(item.to) ? 'active' : ''}`}
          onClick={() => setMobileMenuOpen(false)}
        >
          {item.label}
        </Link>
      )
    }
    if (item.type === 'dropdown') {
      return (
        <div
          key={item.label}
          className="dropdown-container"
          onMouseEnter={() => setOpenDropdown(item.label)}
          onMouseLeave={() => setOpenDropdown(null)}
        >
          <button className="nav-dropdown-btn">
            {item.label} <span className="dropdown-arrow">▼</span>
          </button>
          {openDropdown === item.label && (
            <div className="dropdown-menu">
              {item.items.map((sub) => (
                <div
                  key={sub.label}
                  className="dropdown-item"
                  onClick={() => handleDropdownClick(sub.href || sub.path, sub.external)}
                >
                  {sub.label}
                </div>
              ))}
            </div>
          )}
        </div>
      )
    }
    return null
  }

  const renderMobileNavItem = (item) => {
    if (item.to) {
      return (
        <Link
          key={item.to}
          to={item.to}
          className={`mobile-nav-link ${isActive(item.to) ? 'active' : ''}`}
          onClick={() => setMobileMenuOpen(false)}
        >
          {item.label}
        </Link>
      )
    }
    if (item.type === 'dropdown') {
      return (
        <div key={item.label} className="mobile-dropdown">
          <div className="mobile-dropdown-label">{item.label}</div>
          <div className="mobile-dropdown-items">
            {item.items.map((sub) => (
              <div
                key={sub.label}
                className="mobile-dropdown-item"
                onClick={() => handleDropdownClick(sub.href || sub.path, sub.external)}
              >
                {sub.label}
              </div>
            ))}
          </div>
        </div>
      )
    }
    return null
  }

  return (
    <>
      <header className="site-header">
        <div className="header-container">
          <Link to={isAuth ? "/dashboard" : "/"} className="logo">
            <div className="logo-icon">R</div>
            <span className="logo-text">Remote<span>Team</span></span>
          </Link>

          <nav className="desktop-nav">{currentLinks.map(renderNavItem)}</nav>

          <div className="header-actions">
            {isAuth && (
              <form onSubmit={handleSearch} className="search-form">
                <input
                  type="text"
                  placeholder={t.search}
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  className="search-input"
                />
              </form>
            )}
            <button onClick={() => setAiModalOpen(true)} className="ai-btn">🤖 AI</button>
            <select value={lang} onChange={(e) => setLang(e.target.value)} className="lang-select">
              {languages.map((l) => (
                <option key={l.code} value={l.code}>{l.flag} {l.name}</option>
              ))}
            </select>
            <button onClick={() => setTheme(theme === 'dark' ? 'light' : 'dark')} className="theme-btn">
              {theme === 'dark' ? '☀️' : '🌙'}
            </button>
            {isAuth ? (
              <UserDropdown user={user} />
            ) : (
              <div className="auth-buttons">
                <Link to="/login" className="btn btn-secondary btn-sm">{t.login}</Link>
                <Link to="/register" className="btn btn-primary btn-sm">{t.register}</Link>
              </div>
            )}
          </div>

          <button className="mobile-menu-btn" onClick={() => setMobileMenuOpen(!mobileMenuOpen)}>☰</button>
        </div>

        {mobileMenuOpen && (
          <div className="mobile-menu-container">
            <div className="mobile-menu-header">
              <span>Menu</span>
              <button onClick={() => setMobileMenuOpen(false)}>✕</button>
            </div>
            <div className="mobile-nav-list">
              {currentLinks.map(renderMobileNavItem)}
              {isAuth && (
                <form onSubmit={handleSearch} className="mobile-search">
                  <input
                    type="text"
                    placeholder={t.search}
                    value={search}
                    onChange={(e) => setSearch(e.target.value)}
                    className="input"
                  />
                  <button type="submit" className="btn btn-primary btn-sm">Go</button>
                </form>
              )}
              <div className="mobile-actions">
                <div className="mobile-action-group">
                  <span>Language:</span>
                  <select value={lang} onChange={(e) => setLang(e.target.value)} className="lang-select">
                    {languages.map((l) => (
                      <option key={l.code} value={l.code}>{l.flag} {l.name}</option>
                    ))}
                  </select>
                </div>
                <div className="mobile-action-group">
                  <span>Theme:</span>
                  <button onClick={() => setTheme(theme === 'dark' ? 'light' : 'dark')} className="theme-btn">
                    {theme === 'dark' ? 'Light' : 'Dark'}
                  </button>
                </div>
                <button
                  onClick={() => { setAiModalOpen(true); setMobileMenuOpen(false); }}
                  className="ai-btn-mobile"
                >
                  🤖 AI Assistant
                </button>
                {!isAuth && (
                  <div className="mobile-auth-buttons">
                    <Link to="/login" onClick={() => setMobileMenuOpen(false)} className="btn btn-secondary">{t.login}</Link>
                    <Link to="/register" onClick={() => setMobileMenuOpen(false)} className="btn btn-primary">{t.register}</Link>
                  </div>
                )}
                {isAuth && <UserDropdown user={user} mobile />}
              </div>
            </div>
          </div>
        )}
      </header>
      <AIAssistantModal isOpen={aiModalOpen} onClose={() => setAiModalOpen(false)} />

      <style>{`
        .site-header {
          position: sticky;
          top: 0;
          z-index: 1000;
          background: rgba(0, 0, 0, 0.9);
          backdrop-filter: blur(12px);
          border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .header-container {
          max-width: 1400px;
          margin: 0 auto;
          padding: 0 20px;
          height: 64px;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 16px;
        }
        .logo {
          display: flex;
          align-items: center;
          gap: 10px;
          text-decoration: none;
          flex-shrink: 0;
        }
        .logo-icon {
          width: 34px;
          height: 34px;
          border-radius: 10px;
          background: linear-gradient(135deg, var(--brand), var(--brand-dark));
          display: flex;
          align-items: center;
          justify-content: center;
          color: white;
          font-weight: 800;
          font-size: 16px;
        }
        .logo-text {
          font-weight: 700;
          font-size: 15px;
          color: var(--text);
        }
        .logo-text span {
          color: var(--brand);
        }
        .desktop-nav {
          display: flex;
          align-items: center;
          gap: 12px;
        }
        .nav-link, .nav-dropdown-btn {
          padding: 6px 14px;
          border-radius: 8px;
          font-size: 0.9rem;
          font-weight: 600;
          color: var(--text2);
          text-decoration: none;
          background: none;
          border: none;
          cursor: pointer;
          transition: all 0.2s;
        }
        .nav-link.active {
          color: var(--brand);
          background: rgba(79,70,229,0.12);
        }
        .nav-link:hover, .nav-dropdown-btn:hover {
          color: var(--text);
          background: rgba(79,70,229,0.08);
        }
        .dropdown-container {
          position: relative;
        }
        .dropdown-menu {
          position: absolute;
          top: 100%;
          left: 0;
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-radius: 12px;
          min-width: 180px;
          padding: 8px 0;
          z-index: 200;
          backdrop-filter: blur(8px);
        }
        .dropdown-item {
          padding: 8px 16px;
          font-size: 0.85rem;
          cursor: pointer;
        }
        .dropdown-item:hover {
          background: var(--brand-bg);
          color: var(--brand);
        }
        .header-actions {
          display: flex;
          align-items: center;
          gap: 12px;
        }
        .search-form {
          min-width: 160px;
        }
        .search-input {
          background: var(--bg3);
          border: 1px solid var(--border);
          border-radius: 20px;
          padding: 6px 12px;
          font-size: 13px;
          width: 100%;
          outline: none;
          color: var(--text);
        }
        .search-input:focus {
          border-color: var(--brand);
          box-shadow: 0 0 0 2px rgba(79,70,229,0.2);
        }
        .ai-btn, .theme-btn, .lang-select {
          background: var(--bg3);
          border: 1px solid var(--border);
          border-radius: 20px;
          padding: 5px 12px;
          font-size: 12px;
          cursor: pointer;
          color: var(--text2);
        }
        .ai-btn {
          background: linear-gradient(135deg, var(--brand), var(--brand-dark));
          color: white;
          border: none;
        }
        .mobile-menu-btn {
          display: none;
          background: none;
          border: none;
          font-size: 1.8rem;
          cursor: pointer;
          color: var(--text);
        }

        /* Mobile menu – high contrast, easy to see */
        .mobile-menu-container {
          position: fixed;
          top: 64px;
          left: 0;
          right: 0;
          bottom: 0;
          background: var(--bg-card);
          backdrop-filter: blur(20px);
          z-index: 999;
          padding: 20px;
          overflow-y: auto;
          animation: fadeInUp 0.2s ease;
          border-top: 1px solid var(--border);
        }
        .mobile-menu-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding-bottom: 16px;
          border-bottom: 2px solid var(--border);
          margin-bottom: 16px;
          font-weight: 700;
          font-size: 1.2rem;
          color: var(--text);
        }
        .mobile-nav-list {
          display: flex;
          flex-direction: column;
          gap: 12px;
        }
        .mobile-nav-link {
          display: block;
          padding: 12px 16px;
          background: var(--bg3);
          border-radius: 12px;
          text-decoration: none;
          color: var(--text);
          font-weight: 600;
          font-size: 1rem;
          border: 1px solid var(--border);
        }
        .mobile-nav-link.active {
          background: var(--brand);
          color: white;
          border-color: var(--brand);
        }
        .mobile-dropdown {
          background: var(--bg3);
          border-radius: 12px;
          border: 1px solid var(--border);
          overflow: hidden;
        }
        .mobile-dropdown-label {
          padding: 12px 16px;
          font-weight: 700;
          color: var(--text);
          background: var(--bg2);
          border-bottom: 1px solid var(--border);
        }
        .mobile-dropdown-items {
          display: flex;
          flex-direction: column;
        }
        .mobile-dropdown-item {
          padding: 10px 16px 10px 32px;
          color: var(--text2);
          cursor: pointer;
          border-top: 1px solid var(--border);
        }
        .mobile-dropdown-item:hover {
          background: var(--brand-bg);
          color: var(--brand);
        }
        .mobile-search {
          display: flex;
          gap: 8px;
          margin: 8px 0;
        }
        .mobile-actions {
          margin-top: 16px;
          display: flex;
          flex-direction: column;
          gap: 12px;
        }
        .mobile-action-group {
          display: flex;
          align-items: center;
          justify-content: space-between;
          background: var(--bg3);
          padding: 12px 16px;
          border-radius: 12px;
          border: 1px solid var(--border);
        }
        .ai-btn-mobile {
          background: linear-gradient(135deg, var(--brand), var(--brand-dark));
          color: white;
          border: none;
          border-radius: 12px;
          padding: 12px;
          width: 100%;
          font-weight: 600;
          cursor: pointer;
        }
        .mobile-auth-buttons {
          display: flex;
          gap: 10px;
          margin-top: 8px;
        }
        .mobile-auth-buttons .btn {
          flex: 1;
          text-align: center;
        }

        @media (max-width: 1024px) {
          .desktop-nav, .header-actions {
            display: none;
          }
          .mobile-menu-btn {
            display: block;
          }
        }
        @media (max-width: 640px) {
          .header-container {
            padding: 0 12px;
          }
          .logo-text {
            font-size: 13px;
          }
          .mobile-menu-container {
            padding: 12px;
          }
        }
      `}</style>
    </>
  )
}
